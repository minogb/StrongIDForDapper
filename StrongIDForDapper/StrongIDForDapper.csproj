<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <EnablePackageValidation>true</EnablePackageValidation>
    <ImplicitUsings>disable</ImplicitUsings>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <Title>Strong ID For Dapper</Title>
    <Authors>Bradley Minogue</Authors>
    <Description>Value Converter For Strong ID</Description>
    <RepositoryUrl>https://github.com/minogb/StrongIDForEntityFramework</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>database; api; strong; type</PackageTags>
    <Version>1.0.2</Version>
    <PackageId>Minogb.Strong.ID.EntityConverter</PackageId>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Dapper" Version="2.1.72" />
    <PackageReference Include="Minogb.Strong.ID" Version="1.0.2" />
  </ItemGroup>
</Project>
